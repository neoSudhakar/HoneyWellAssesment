#!/bin/sh
# Minimal Maven Wrapper script (Unix)
BASEDIR=$(cd "$(dirname "$0")"; pwd -P)
WRAPPER_DIR="$BASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"
MVNW_REPOURL="https://repo.maven.apache.org/maven2"

mkdir -p "$WRAPPER_DIR"

if [ ! -f "$WRAPPER_JAR" ]; then
  WRAPPER_URL="$MVNW_REPOURL/io/takari/maven-wrapper/0.5.6/maven-wrapper-0.5.6.jar"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$WRAPPER_URL" -o "$WRAPPER_JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$WRAPPER_URL" -O "$WRAPPER_JAR"
  else
    echo "Neither curl nor wget is available to download the Maven Wrapper jar."
    exit 1
  fi
fi

exec java -jar "$WRAPPER_JAR" -Dmaven.multiModuleProjectDirectory="$BASEDIR" "$@"

